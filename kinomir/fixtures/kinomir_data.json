{
  "model": "reviews.review",
  "pk": 1,
  "fields": {
    "movie_title": "Джон Неделя 4",
    "director": "Чад Стахелски",
    "release_year": 2023,
    "text": "«Джон Уик (Неделя) 4» — это не просто боевик, а настоящее танго с пулями на 2 часа 49 минут. Чад Стахелски берёт всё лучшее из предыдущих частей и возводит это в абсолют. Экшен здесь поставлен настолько виртуозно, что сцена драки в осакском отеле «Континенталь» или перестрелка сверху вниз в Париже уже претендуют на место в учебниках киноискусства.\r\n\r\nКиану Ривз по-прежнему немногословен и смертоносен, а его оппоненты — Скотт Эдкинс и Билл Скарсгард — добавляют блюду перца. Отдельное удовольствие — Донни Йен вслепую, который крадёт каждый кадр. Да, фильм немного перенасыщен, но когда финал подводит черту под всей сагой, становится понятно: лучше закончить на этой эпической ноте уже нельзя. Обязательно к просмотру на большом экране или в хороших наушниках.",
    "rating": 9,
    "trailer_url": "https://vkvideo.ru/video-182204191_456244111?list=ln-SsZQRcXTJWbGCP9HPv",
    "is_approved": true,
    "author": 2,
    "pub_date": "2026-04-22T10:03:05.475Z",
    "genre": 1
  }
},
